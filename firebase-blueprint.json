{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "username": { "type": "string" },
        "hasSyncedContacts": { "type": "boolean" },
        "hasSetupWidget": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "createdAt"]
    },
    "Friendship": {
      "title": "Friendship",
      "description": "Relationship between two users",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["status", "uid", "updatedAt"]
    },
    "Photo": {
      "title": "Photo",
      "description": "A photo shared with friends",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "imageUrl": { "type": "string" },
        "caption": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "reactions": {
          "type": "object",
          "description": "Map of userId to emoji reaction"
        },
        "recipientIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of friend IDs who can see this photo"
        }
      },
      "required": ["senderId", "imageUrl", "createdAt", "recipientIds"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/friends/{friendId}": {
      "schema": "Friendship",
      "description": "User friends list"
    },
    "/photos/{photoId}": {
      "schema": "Photo",
      "description": "All shared photos"
    }
  }
}
